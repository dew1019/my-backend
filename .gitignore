# Node / OS / tooling
node_modules/
logs/
npm-debug.log*
yarn-error.log*
.DS_Store
coverage/
tmp/
.cache/

# Build artifacts
dist/
build/

# Hosting / runtimes
.vercel/
.render/

# Puppeteer cache
puppeteer/.local-chromium/
**/chromium*/

# Local env
.env
.env.*
.env.local

# Generated runtime files you DON'T want in git
pdfs/
signatures/

# ⚠️ DO NOT ignore all JSON globally (keeps package.json, etc.)
# If you have secret JSON keys, ignore them explicitly:
client-*.json

# PDFs:
# We IGNORE generated PDFs, but we KEEP template PDFs:
*.pdf
!pdf-templates/*.pdf
